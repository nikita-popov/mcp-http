# Copy to /etc/mcp-http/<name>.env (for systemd template) or .env (for manual run).
# All variables are optional; defaults are shown.

# Shell command to launch the upstream MCP stdio server.
MCP_HTTP_CMD=python -m mempalace.mcp_server

# Port uvicorn listens on (used by the systemd template mcp-http@.service).
MCP_HTTP_PORT=8765

# File containing bearer tokens (one per line, # = comment).
# If the file is missing, auth is DISABLED (dev mode).
MCP_HTTP_TOKENS_FILE=/etc/mcp-http/tokens

# Comma-separated external hostnames allowed to connect.
# FastMCP blocks non-localhost hosts by default (DNS rebinding protection).
# Set to your reverse-proxy hostname, e.g.: chat.example.com
# Use "*" to disable the check entirely (not recommended).
MCP_HTTP_ALLOWED_HOSTS=

# Timeouts (seconds)
MCP_HTTP_LIST_TOOLS_TIMEOUT=30
MCP_HTTP_CALL_TOOL_TIMEOUT=60
