# mcp-http configuration
# Copy to /etc/mcp-http/<name>.env and adjust.

# Required: command to launch the upstream stdio MCP server.
# Arguments are split by whitespace.
MCP_HTTP_CMD=your-mcp-server

# Port to listen on (127.0.0.1 only; expose via nginx reverse proxy).
MCP_HTTP_PORT=8770

# Path to a file with Bearer tokens (one per line, # for comments).
# Leave empty to disable authentication.
MCP_HTTP_TOKENS_FILE=/etc/mcp-http/tokens

# Comma-separated list of allowed Host headers (DNS rebinding protection).
# Leave empty to allow any host (safe behind nginx).
MCP_HTTP_ALLOWED_HOSTS=

# Timeout for a single tool call (Go duration: 30s, 1m, etc.).
MCP_HTTP_TOOL_TIMEOUT=30s
